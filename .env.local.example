# Copy to .env.local (gitignored — NEVER commit .env.local)
#
# GEMINI_API_KEY: only needed for optional local scripts that call Google API
# directly from Node. The app uses Supabase Edge Functions; set the key there:
#
#   npx supabase secrets set GEMINI_API_KEY="your-key" --project-ref zghzhfheyawvbdddsybe
#
# Do NOT add GEMINI_API_KEY to .env (that file may be committed).

# VITE_* below are optional overrides for local dev (public anon key is fine in .env)
# VITE_SUPABASE_URL=https://zghzhfheyawvbdddsybe.supabase.co
# VITE_SUPABASE_PUBLISHABLE_KEY=

# Optional — local-only, never commit
# GEMINI_API_KEY=
# GOOGLE_API_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# Back-office seed script (optional local only)
# BACK_OFFICE_EMAIL=backoffice@logitrainerstudio.app
# BACK_OFFICE_PASSWORD=
# BACK_OFFICE_SETUP_SECRET=
