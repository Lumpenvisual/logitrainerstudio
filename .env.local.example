# Copy to .env.local (gitignored — NEVER commit .env.local)
#
# GEMINI_API_KEY: only needed for optional local scripts that call Google API
# directly from Node. The app uses Supabase Edge Functions; set the key there:
#
#   npx supabase secrets set GEMINI_API_KEY="your-key" --project-ref zghzhfheyawvbdddsybe
#
# Do NOT add GEMINI_API_KEY to .env (that file may be committed).

# VITE_* below are optional overrides for local dev (public anon key is fine in .env)
# VITE_SUPABASE_URL=https://zghzhfheyawvbdddsybe.supabase.co
# VITE_SUPABASE_PUBLISHABLE_KEY=

# Optional — local-only, never commit
# GEMINI_API_KEY=
# GOOGLE_API_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# Unified studio account (hub + Supabase) — same email & password everywhere
# VITE_UNIFIED_EMAIL=backoffice@logitrainerstudio.app
# VITE_UNIFIED_PASSWORD=LTS-Mayo2026-7kQ!
# BACK_OFFICE_EMAIL=backoffice@logitrainerstudio.app
# BACK_OFFICE_PASSWORD=LTS-Mayo2026-7kQ!
# BACK_OFFICE_SETUP_SECRET=

# Cloudflare Tunnel (opcional — detección en /studio)
# VITE_TUNNEL_HOST=studio.logitrainerstudio.com
# VITE_TUNNEL_PUBLIC_URL=https://studio.logitrainerstudio.com
# CLOUDFLARE_TUNNEL_NAME=logitrainer-studio
# CLOUDFLARE_TUNNEL_HOST=studio.logitrainerstudio.com
# Token desde Zero Trust > Networks > Tunnels > Configure > Install connector (sin cloudflared login)
# CLOUDFLARE_TUNNEL_TOKEN=
